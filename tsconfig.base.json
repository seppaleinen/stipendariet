{
  "compilerOptions": {
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "esModuleInterop": false,
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,

    /* JSX */
    "jsx": "react-jsx",

    /* Output — each app overrides to noEmit since they're bundler-only */
    "target": "ES2020",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "module": "ESNext",

    /* Workspace path aliases — resolved relative to base.tsconfig location (monorepo root) */
    "baseUrl": ".",
    "paths": {
      "@stipendariet/ui": ["./packages/ui/src/index.ts"],
      "@stipendariet/types": ["./packages/types/src/index.ts"],
      "@stipendariet/api-client": ["./packages/api-client/src/index.ts"]
    }
  }
}
