{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    /* Override from base — keep strict:false to match existing behavior */
    "strict": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noImplicitAny": false,
    "noFallthroughCasesInSwitch": false,

    /* Local app alias — must match vite.config.ts resolve.alias */
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["src"]
}
